{
  "name": "car-parking-multiplayer",
  "version": "1.0.0",
  "description": "A multiplayer car parking game with real-time physics",
  "main": "server/index.js",
  "engines": {
    "node": "18.x"
  },
  "scripts": {
    "server": "node server/index.js",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "client": "cd client && http-server -p 3000 -c-1",
    "start": "node server/index.js"
  },
  "keywords": ["game", "multiplayer", "parking", "phaser"],
  "author": "pdidisenior-rgb",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "socket.io": "^4.5.4",
    "cors": "^2.8.5",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "concurrently": "^7.0.0",
    "http-server": "^14.1.1"
  }
}
